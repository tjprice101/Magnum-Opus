using System;
using Microsoft.Xna.Framework;
using Microsoft.Xna.Framework.Graphics;
using Terraria;
using Terraria.ID;
using MagnumOpus.Common.Systems;
using MagnumOpus.Common.Systems.VFX;
using MagnumOpus.Common.Systems.Particles;

namespace MagnumOpus.Content.ClairDeLune.Weapons.Ranged
{
    // =========================================================================
    //  StarfallWhisperVFX — Starfall Trail
    //  Shader: StarfallTrail.fx (StarfallBolt + StarfallWake)
    //  Identity: Falling star bolt — each shot is a tiny meteor falling
    //  from a dream sky, trailing luminous stardust in its wake.
    // =========================================================================
    public static class StarfallWhisperVFX
    {
        public static void HoldItemVFX(Player player)
        {
            float time = (float)Main.timeForVisualEffects;

            // Drifting stardust motes — tiny falling star particles gently descending around the player
            if (Main.rand.NextBool(3))
            {
                Vector2 spawnPos = player.Center + new Vector2(Main.rand.NextFloat(-25f, 25f), -20f);
                Vector2 vel = new Vector2(Main.rand.NextFloat(-0.2f, 0.2f), Main.rand.NextFloat(0.3f, 0.8f));
                Color starCol = Color.Lerp(ClairDeLunePalette.StarlightSilver, ClairDeLunePalette.PearlBlue,
                    Main.rand.NextFloat());
                Dust d = Dust.NewDustPerfect(spawnPos, DustID.IceTorch, vel, 0, default, 0.35f);
                d.noGravity = true;
                d.fadeIn = 0.5f;
            }

            // Twinkling star sparkles at random positions
            if (Main.rand.NextBool(6))
            {
                var twinkle = new SparkleParticle(
                    player.Center + Main.rand.NextVector2Circular(22f, 22f),
                    Vector2.Zero, ClairDeLunePalette.PearlWhite * 0.5f, 0.12f, 10);
                MagnumParticleHandler.SpawnParticle(twinkle);
            }

            if (Main.rand.NextBool(10))
                ClairDeLuneVFXLibrary.SpawnStarlitSparkles(player.Center, 1, 25f, 0.12f);

            ClairDeLuneVFXLibrary.AddClairDeLuneLight(player.Center, 0.2f);
        }

        public static void PreDrawInWorldBloom(SpriteBatch sb, Texture2D tex, Vector2 pos,
            Vector2 origin, float rotation, float scale)
        {
            if (ClairDeLuneShaderManager.HasStarfallTrail)
            {
                ClairDeLuneShaderManager.BeginShaderAdditive(sb);
                ClairDeLuneShaderManager.ApplyStarfallWake((float)Main.timeForVisualEffects * 0.03f);

                sb.Draw(tex, pos - Main.screenPosition, null,
                    ClairDeLunePalette.StarlightSilver * 0.5f, rotation, origin, scale * 1.03f,
                    SpriteEffects.None, 0f);

                ClairDeLuneShaderManager.RestoreSpriteBatch(sb);
            }
            else
            {
                ClairDeLuneVFXLibrary.DrawClairDeLuneBloomStack(sb, pos,
                    ClairDeLunePalette.StarlightSilver, ClairDeLunePalette.PearlBlue, scale * 0.25f, 0.35f);
            }
        }

        public static void BoltTrailVFX(Vector2 boltPos, Vector2 boltVelocity)
        {
            Vector2 perpendicular = new Vector2(-boltVelocity.Y, boltVelocity.X);
            if (perpendicular != Vector2.Zero) perpendicular.Normalize();
            float time = (float)Main.timeForVisualEffects;

            // === SIGNATURE: COMET-WAKE STARDUST TRAIL ===
            // Long luminous tail with scattered twinkling star particles

            // Core ice wake — bright concentrated line
            Dust d = Dust.NewDustPerfect(boltPos, DustID.IceTorch,
                boltVelocity * -0.1f + perpendicular * Main.rand.NextFloat(-0.6f, 0.6f),
                0, default, 0.65f);
            d.noGravity = true;
            d.fadeIn = 0.7f;

            // Stardust sparkle scatter — tiny twinkling points shed behind the bolt
            if (Main.GameUpdateCount % 2 == 0)
            {
                float drift = Main.rand.NextFloat(-1.2f, 1.2f);
                Vector2 sparkPos = boltPos + perpendicular * drift * 5f;
                Vector2 sparkVel = boltVelocity * -0.15f + perpendicular * drift * 0.3f;
                Color sparkCol = Color.Lerp(ClairDeLunePalette.StarlightSilver, ClairDeLunePalette.PearlWhite,
                    (float)Math.Sin(time * 0.12f + drift) * 0.5f + 0.5f);

                var stardust = new SparkleParticle(sparkPos, sparkVel, sparkCol * 0.7f, 0.18f, 12);
                MagnumParticleHandler.SpawnParticle(stardust);
            }

            // Pearl-blue corona glow trailing the bolt head
            if (Main.GameUpdateCount % 3 == 0)
            {
                Color coronaCol = ClairDeLunePalette.PaletteLerp(
                    ClairDeLunePalette.StarfallWhisperShot,
                    (float)Math.Sin(time * 0.06f) * 0.3f + 0.5f);
                var corona = new GenericGlowParticle(
                    boltPos, boltVelocity * -0.06f, coronaCol * 0.5f, 0.2f, 10, true);
                MagnumParticleHandler.SpawnParticle(corona);
            }

            // Silver flame accents
            if (Main.GameUpdateCount % 2 == 0)
            {
                Dust sparkle = Dust.NewDustPerfect(boltPos, DustID.SilverFlame,
                    boltVelocity * -0.14f + Main.rand.NextVector2Circular(0.5f, 0.5f),
                    0, default, 0.38f);
                sparkle.noGravity = true;
            }

            if (Main.GameUpdateCount % 7 == 0)
                ClairDeLuneVFXLibrary.SpawnMusicNotes(boltPos, 1, 6f, 0.2f, 0.4f, 10);

            ClairDeLuneVFXLibrary.AddPaletteLighting(boltPos, 0.3f, 0.35f);
        }

        public static void BoltImpactVFX(Vector2 hitPos)
        {
            ClairDeLuneVFXLibrary.ProjectileImpact(hitPos, 0);

            // === SIGNATURE: STARBURST SHATTER — a falling star shatters on impact ===
            // Star-shaped radial with strong twinkling sparkle
            int dustCount = 16;
            for (int i = 0; i < dustCount; i++)
            {
                float angle = MathHelper.TwoPi * i / dustCount;
                // Star-shaped pulsing speed (faster on cardinal/diagonal axes)
                float starPulse = 1f + 0.3f * (float)Math.Abs(Math.Sin(angle * 2f));
                float speed = (4f + Main.rand.NextFloat() * 3f) * starPulse;
                Vector2 vel = angle.ToRotationVector2() * speed;
                int dustType = (i % 3 == 0) ? DustID.SilverFlame : DustID.IceTorch;
                Dust d = Dust.NewDustPerfect(hitPos, dustType, vel, 0, default, 0.9f);
                d.noGravity = true;
                d.fadeIn = 1f;

                // Starlight sparkle overlay
                if (i % 2 == 0)
                {
                    Color sparkCol = Color.Lerp(ClairDeLunePalette.StarlightSilver, ClairDeLunePalette.PearlWhite,
                        Main.rand.NextFloat());
                    var spark = new SparkleParticle(hitPos, vel * 0.6f, sparkCol * 0.8f, 0.22f, 14);
                    MagnumParticleHandler.SpawnParticle(spark);
                }
            }

            // Star-point flare — 4-pointed cross of bright particles
            for (int p = 0; p < 4; p++)
            {
                float pointAngle = p * MathHelper.PiOver2;
                Vector2 pointVel = pointAngle.ToRotationVector2() * 6f;
                var flare = new GenericGlowParticle(hitPos, pointVel,
                    ClairDeLunePalette.PearlWhite * 0.8f, 0.3f, 12, true);
                MagnumParticleHandler.SpawnParticle(flare);
            }

            ClairDeLuneVFXLibrary.SpawnPearlBurst(hitPos, 10, 4.5f, 0.32f);
            ClairDeLuneVFXLibrary.SpawnStarlitSparkles(hitPos, 7, 28f, 0.24f);
            ClairDeLuneVFXLibrary.SpawnMusicNotes(hitPos, 2, 12f, 0.35f, 0.65f, 18);
            ClairDeLuneVFXLibrary.DrawBloom(hitPos, 0.45f, 0.75f);
            ClairDeLuneVFXLibrary.AddPaletteLighting(hitPos, 0.3f, 0.55f);
        }

        public static void ChargeUpVFX(Vector2 muzzlePos, float chargeProgress)
        {
            float intensity = MathHelper.Clamp(chargeProgress, 0f, 1f);
            int dustCount = (int)(3 * intensity) + 1;

            for (int i = 0; i < dustCount; i++)
            {
                float angle = Main.rand.NextFloat() * MathHelper.TwoPi;
                float radius = 30f * (1f - intensity) + 5f;
                Vector2 dustPos = muzzlePos + angle.ToRotationVector2() * radius;
                Vector2 vel = (muzzlePos - dustPos) * 0.08f * intensity;
                Dust d = Dust.NewDustPerfect(dustPos, DustID.IceTorch, vel, 0, default, 0.5f * intensity);
                d.noGravity = true;
                d.fadeIn = 0.6f;
            }

            if (intensity > 0.6f)
                ClairDeLuneVFXLibrary.SpawnPearlSparkle(muzzlePos, Vector2.Zero);

            ClairDeLuneVFXLibrary.AddPaletteLighting(muzzlePos, 0.3f, 0.3f * intensity);
        }
    }

    // =========================================================================
    //  MidnightMechanismVFX — Gatling Blur
    //  Shader: GatlingBlur.fx (GatlingBarrelBlur + GatlingMuzzle)
    //  Identity: Clockwork barrel blur — rapid-fire mechanical mayhem,
    //  brass-gold muzzle flashes and spinning barrel motion blur.
    // =========================================================================
    public static class MidnightMechanismVFX
    {
        public static void HoldItemVFX(Player player)
        {
            float time = (float)Main.timeForVisualEffects;

            // Spinning gear cog idle — tiny brass dots rotating in a tight circle like a spinning barrel
            if (Main.rand.NextBool(3))
            {
                float cogAngle = time * 0.08f;
                float cogRadius = 10f;
                for (int i = 0; i < 2; i++)
                {
                    float partAngle = cogAngle + i * MathHelper.Pi;
                    Vector2 cogPos = player.Center + partAngle.ToRotationVector2() * cogRadius;
                    Dust d = Dust.NewDustPerfect(cogPos, DustID.GoldFlame,
                        (partAngle + MathHelper.PiOver2).ToRotationVector2() * 0.3f, 0, default, 0.3f);
                    d.noGravity = true;
                    d.fadeIn = 0.4f;
                }
            }

            // Warm brass ambient glow
            if (Main.rand.NextBool(6))
            {
                Vector2 offset = Main.rand.NextVector2Circular(18f, 18f);
                var warmGlow = new GenericGlowParticle(
                    player.Center + offset, Vector2.Zero,
                    ClairDeLunePalette.ClockworkBrass * 0.3f, 0.1f, 8, true);
                MagnumParticleHandler.SpawnParticle(warmGlow);
            }

            ClairDeLuneVFXLibrary.AmbientClockworkAura(player.Center, time);
            ClairDeLuneVFXLibrary.AddClairDeLuneLight(player.Center, 0.2f);
        }

        public static void PreDrawInWorldBloom(SpriteBatch sb, Texture2D tex, Vector2 pos,
            Vector2 origin, float rotation, float scale)
        {
            if (ClairDeLuneShaderManager.HasGatlingBlur)
            {
                ClairDeLuneShaderManager.BeginShaderAdditive(sb);
                ClairDeLuneShaderManager.ApplyGatlingMuzzle((float)Main.timeForVisualEffects * 0.04f);

                sb.Draw(tex, pos - Main.screenPosition, null,
                    ClairDeLunePalette.ClockworkBrass * 0.5f, rotation, origin, scale * 1.03f,
                    SpriteEffects.None, 0f);

                ClairDeLuneShaderManager.RestoreSpriteBatch(sb);
            }
            else
            {
                ClairDeLuneVFXLibrary.DrawClairDeLuneBloomStack(sb, pos,
                    ClairDeLunePalette.ClockworkBrass, ClairDeLunePalette.MoonbeamGold, scale * 0.25f, 0.35f);
            }
        }

        public static void BulletTrailVFX(Vector2 bulletPos, Vector2 bulletVelocity)
        {
            Vector2 perpendicular = new Vector2(-bulletVelocity.Y, bulletVelocity.X);
            if (perpendicular != Vector2.Zero) perpendicular.Normalize();
            float time = (float)Main.timeForVisualEffects;

            // === SIGNATURE: RAPID BRASS STREAK — fast, hot, mechanical ===
            // Short sharp lines of gold-orange along the bullet path

            // Core gold flame streak
            Dust d = Dust.NewDustPerfect(bulletPos, DustID.GoldFlame,
                bulletVelocity * -0.06f + perpendicular * Main.rand.NextFloat(-0.4f, 0.4f),
                0, default, 0.55f);
            d.noGravity = true;
            d.fadeIn = 0.6f;

            // Rapid alternating brass-pearl micro-sparks (mechanical ricochet feel)
            if (Main.GameUpdateCount % 2 == 0)
            {
                float side = (Main.GameUpdateCount % 4 < 2) ? 1f : -1f;
                Vector2 microVel = perpendicular * side * 1.5f + bulletVelocity * -0.08f;
                Color microCol = (Main.GameUpdateCount % 4 < 2)
                    ? ClairDeLunePalette.ClockworkBrass
                    : ClairDeLunePalette.PearlBlue;
                var micro = new SparkleParticle(
                    bulletPos, microVel, microCol * 0.6f, 0.12f, 6);
                MagnumParticleHandler.SpawnParticle(micro);
            }

            // Pearl accent trail
            if (Main.GameUpdateCount % 3 == 0)
            {
                Dust spark = Dust.NewDustPerfect(bulletPos, DustID.IceTorch,
                    bulletVelocity * -0.12f, 0, default, 0.28f);
                spark.noGravity = true;
            }

            ClairDeLuneVFXLibrary.AddPaletteLighting(bulletPos, 0.6f, 0.28f);
        }

        public static void BulletImpactVFX(Vector2 hitPos)
        {
            ClairDeLuneVFXLibrary.ProjectileImpact(hitPos, 0);

            // === SIGNATURE: BRASS RICOCHET SCATTER — mechanical spark shower ===
            int dustCount = 12;
            for (int i = 0; i < dustCount; i++)
            {
                float angle = MathHelper.TwoPi * i / dustCount;
                float speed = 3.5f + Main.rand.NextFloat() * 2.5f;
                Vector2 vel = angle.ToRotationVector2() * speed;
                int dustType = (i % 2 == 0) ? DustID.GoldFlame : DustID.IceTorch;
                Dust d = Dust.NewDustPerfect(hitPos, dustType, vel, 0, default, 0.75f);
                d.noGravity = true;
                d.fadeIn = 0.9f;

                // Brass glow accents on every other spark
                if (i % 3 == 0)
                {
                    var brassGlow = new GenericGlowParticle(
                        hitPos, vel * 0.6f, ClairDeLunePalette.MoonbeamGold * 0.6f, 0.18f, 10, true);
                    MagnumParticleHandler.SpawnParticle(brassGlow);
                }
            }

            ClairDeLuneVFXLibrary.SpawnPearlBurst(hitPos, 4, 2.5f, 0.2f);
            ClairDeLuneVFXLibrary.SpawnMusicNotes(hitPos, 1, 8f, 0.3f, 0.5f, 12);
            ClairDeLuneVFXLibrary.DrawBloom(hitPos, 0.32f, 0.55f);
            ClairDeLuneVFXLibrary.AddPaletteLighting(hitPos, 0.6f, 0.45f);
        }

        public static void SpinUpVFX(Vector2 barrelPos, float spinProgress)
        {
            float intensity = MathHelper.Clamp(spinProgress, 0f, 1f);

            if (Main.rand.NextBool(Math.Max(1, (int)(6 * (1f - intensity)))))
            {
                float angle = Main.rand.NextFloat() * MathHelper.TwoPi;
                Vector2 sparkPos = barrelPos + angle.ToRotationVector2() * (8f + 6f * intensity);
                Vector2 vel = angle.ToRotationVector2() * 2f * intensity;
                Dust d = Dust.NewDustPerfect(sparkPos, DustID.GoldFlame, vel, 0, default, 0.5f * intensity);
                d.noGravity = true;
            }

            if (intensity > 0.5f && Main.GameUpdateCount % 4 == 0)
                ClairDeLuneVFXLibrary.SpawnMusicNotes(barrelPos, 1, 8f, 0.3f, 0.5f * intensity, 12);

            ClairDeLuneVFXLibrary.AddPaletteLighting(barrelPos, 0.6f, 0.3f * intensity);
        }
    }

    // =========================================================================
    //  CogAndHammerVFX — Singularity Pull
    //  Shader: SingularityPull.fx (SingularityVortex + SingularityCore)
    //  Identity: Temporal singularity collapse — bombs that collapse into
    //  miniature temporal singularities, pulling nearby matter inward.
    // =========================================================================
    public static class CogAndHammerVFX
    {
        public static void HoldItemVFX(Player player)
        {
            float time = (float)Main.timeForVisualEffects;

            // Gravitational pull idle — particles slowly spiral INWARD toward the player
            if (Main.rand.NextBool(2))
            {
                float spawnAngle = Main.rand.NextFloat(MathHelper.TwoPi);
                float spawnDist = 22f + Main.rand.NextFloat(8f);
                Vector2 spawnPos = player.Center + spawnAngle.ToRotationVector2() * spawnDist;
                // Spiral inward: tangential + inward components
                Vector2 inward = (player.Center - spawnPos) * 0.04f;
                Vector2 tangential = new Vector2(-inward.Y, inward.X) * 0.5f;
                Vector2 vel = inward + tangential;

                Color singCol = Color.Lerp(ClairDeLunePalette.DeepNight, ClairDeLunePalette.PearlBlue,
                    Main.rand.NextFloat(0.2f, 0.6f));
                Dust d = Dust.NewDustPerfect(spawnPos, DustID.IceTorch, vel, 0, default, 0.4f);
                d.noGravity = true;
                d.fadeIn = 0.5f;
            }

            // Occasional brass gear mote
            if (Main.rand.NextBool(8))
            {
                Dust brass = Dust.NewDustPerfect(player.Center + Main.rand.NextVector2Circular(16f, 16f),
                    DustID.GoldFlame, Vector2.Zero, 0, default, 0.25f);
                brass.noGravity = true;
            }

            ClairDeLuneVFXLibrary.AddClairDeLuneLight(player.Center, 0.22f);
        }

        public static void PreDrawInWorldBloom(SpriteBatch sb, Texture2D tex, Vector2 pos,
            Vector2 origin, float rotation, float scale)
        {
            if (ClairDeLuneShaderManager.HasSingularityPull)
            {
                ClairDeLuneShaderManager.BeginShaderAdditive(sb);
                ClairDeLuneShaderManager.ApplySingularityCore((float)Main.timeForVisualEffects * 0.03f);

                sb.Draw(tex, pos - Main.screenPosition, null,
                    ClairDeLunePalette.DeepNight * 0.5f, rotation, origin, scale * 1.05f,
                    SpriteEffects.None, 0f);

                ClairDeLuneShaderManager.RestoreSpriteBatch(sb);
            }
            else
            {
                ClairDeLuneVFXLibrary.DrawClairDeLuneBloomStack(sb, pos,
                    ClairDeLunePalette.DeepNight, ClairDeLunePalette.PearlBlue, scale * 0.3f, 0.4f);
            }
        }

        public static void BombTrailVFX(Vector2 bombPos, Vector2 bombVelocity)
        {
            float time = (float)Main.timeForVisualEffects;

            // === SIGNATURE: SPIRALING CONVERGENCE TRAIL — particles being pulled into the bomb ===
            // Inward-spiraling motes around the bomb (gravitational lens hint)

            Dust d = Dust.NewDustPerfect(bombPos, DustID.IceTorch,
                bombVelocity * -0.08f + Main.rand.NextVector2Circular(0.6f, 0.6f),
                0, default, 0.55f);
            d.noGravity = true;
            d.fadeIn = 0.7f;

            // Spiraling convergence motes
            if (Main.GameUpdateCount % 2 == 0)
            {
                float spiralAngle = time * 0.1f + Main.rand.NextFloat(MathHelper.TwoPi);
                float spiralDist = 12f + Main.rand.NextFloat(6f);
                Vector2 motePos = bombPos + spiralAngle.ToRotationVector2() * spiralDist;
                Vector2 inward = (bombPos - motePos) * 0.08f;
                Color moteCol = Color.Lerp(ClairDeLunePalette.DeepNight, ClairDeLunePalette.PearlBlue,
                    Main.rand.NextFloat(0.3f, 0.7f));
                var mote = new GenericGlowParticle(motePos, inward, moteCol * 0.5f, 0.15f, 10, true);
                MagnumParticleHandler.SpawnParticle(mote);
            }

            // Brass gear sparks
            if (Main.GameUpdateCount % 3 == 0)
            {
                Dust brass = Dust.NewDustPerfect(bombPos, DustID.GoldFlame,
                    bombVelocity * -0.12f, 0, default, 0.35f);
                brass.noGravity = true;
            }

            if (Main.GameUpdateCount % 8 == 0)
                ClairDeLuneVFXLibrary.SpawnMusicNotes(bombPos, 1, 6f, 0.2f, 0.4f, 10);

            ClairDeLuneVFXLibrary.AddPaletteLighting(bombPos, 0.3f, 0.32f);
        }

        public static void BombDetonationVFX(Vector2 detonationPos, float radius = 100f)
        {
            // === SIGNATURE: SINGULARITY COLLAPSE — implosion then spherical shockwave ===

            // PHASE 1: Implosion — ring of particles converging inward with spiral
            int outerCount = 22;
            for (int i = 0; i < outerCount; i++)
            {
                float angle = MathHelper.TwoPi * i / outerCount;
                Vector2 edgePos = detonationPos + angle.ToRotationVector2() * radius;
                // Spiral inward (tangential + radial convergence)
                Vector2 radialIn = (detonationPos - edgePos) * 0.06f;
                Vector2 tangential = new Vector2(-radialIn.Y, radialIn.X) * 0.3f;
                Vector2 vel = radialIn + tangential;

                Color implodeCol = Color.Lerp(ClairDeLunePalette.DeepNight, ClairDeLunePalette.PearlBlue,
                    (float)i / outerCount);
                Dust d = Dust.NewDustPerfect(edgePos, DustID.IceTorch, vel, 0, default, 1.1f);
                d.noGravity = true;
                d.fadeIn = 1.2f;

                // Glow particle convergence spiral
                if (i % 2 == 0)
                {
                    var converge = new GenericGlowParticle(edgePos, vel * 1.1f,
                        implodeCol * 0.7f, 0.3f, 16, true);
                    MagnumParticleHandler.SpawnParticle(converge);
                }
            }

            // PHASE 2: Outward detonation — central core explodes
            int innerCount = 16;
            for (int i = 0; i < innerCount; i++)
            {
                float angle = MathHelper.TwoPi * i / innerCount;
                Vector2 vel = angle.ToRotationVector2() * (6f + Main.rand.NextFloat() * 3f);
                int dustType = (i % 3 == 0) ? DustID.GoldFlame : DustID.IceTorch;
                Dust d = Dust.NewDustPerfect(detonationPos, dustType, vel, 0, default, 1f);
                d.noGravity = true;
                d.fadeIn = 1.1f;

                // Core glow detonation particles
                if (i % 2 == 0)
                {
                    Color coreCol = ClairDeLunePalette.PaletteLerp(
                        ClairDeLunePalette.CogAndHammerBlade, (float)i / innerCount);
                    var coreGlow = new GenericGlowParticle(detonationPos, vel * 0.8f,
                        coreCol * 0.8f, 0.35f, 18, true);
                    MagnumParticleHandler.SpawnParticle(coreGlow);
                }
            }

            // Singularity pulsing rings — concentric expanding halos
            ClairDeLuneVFXLibrary.SpawnRadialDustBurst(detonationPos, 20, 8f, DustID.IceTorch);
            ClairDeLuneVFXLibrary.SpawnPearlBurst(detonationPos, 14, 6f, 0.42f);
            ClairDeLuneVFXLibrary.SpawnGradientHaloRings(detonationPos, 6, 0.55f);
            ClairDeLuneVFXLibrary.SpawnConvergingMist(detonationPos, 10, radius * 0.7f, 0.5f);
            ClairDeLuneVFXLibrary.SpawnMusicNotes(detonationPos, 5, 22f, 0.5f, 1f, 32);
            ClairDeLuneVFXLibrary.DrawBloom(detonationPos, 0.9f, 1.1f);
            ClairDeLuneVFXLibrary.AddPaletteLighting(detonationPos, 0.3f, 1.3f);
        }
    }
}
