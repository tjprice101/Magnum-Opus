			ResurrectionOfTheMoon: {
				DisplayName: Resurrection of the Moon
				Tooltip:
					'''
					'From death comes rebirth in silver light 窶・the final movement that silences all'
					Fires a devastating moonlight round with shattering lunar force
					Right-click to cycle between three chamber types:
					  Standard 窶・Ricochets 10 times with escalating crater detonations
					  Comet Core 窶・Pierces through 5 enemies with burning ember wake
					  Supernova 窶・Arcing artillery that detonates in massive AoE
					Requires reloading between shots
					Synergizes with Moonlit Gyre: +25% damage, +15% velocity
					'''
			}
			ResonantCrystalShard: {
				DisplayName: Resonant Crystal Shard
				Tooltip:
					'''
					'Crystallized harmonies from deep within the earth'
					A musical fragment waiting to be awakened
					'''
			}
			MinorMusicNote: {
				DisplayName: Minor Music Note
				Tooltip:
					'''
					'A simple melody fragment'
					Basic crafting material for musical items
					Drops from surface enemies (5% chance)
					'''
			}
			FadedSheetMusic: {
				DisplayName: Faded Sheet Music
				Tooltip:
					'''
					'Ancient compositions, nearly lost to time'
					The notes still hold faint power
					'''
			}
			BrokenBaton: {
				DisplayName: Broken Baton
				Tooltip:
					'''
					'A conductor's tool, snapped but not silenced'
					Still resonates with commanding energy
					'''
			}
			TuningFork: {
				DisplayName: Tuning Fork
				Tooltip:
					'''
					'Strikes the perfect pitch'
					Vibrates with latent musical power
					Drops from cavern enemies (3% chance)
					'''
			}
			OldMetronome: {
				DisplayName: Old Metronome
				Tooltip:
					'''
					'Tick, tock, tick, tock...'
					Still keeps perfect time after all these years
					'''
			}
			RustedClef: {
				DisplayName: Rusted Clef
				Tooltip:
					'''
					'A treble clef frozen in rust and time'
					The ice preserved its musical essence
					'''
			}
			DullResonator: {
				DisplayName: Dull Resonator
				Tooltip:
					'''
					'A dormant resonating disc'
					Awaits the right frequency to awaken
					'''
			}
			DormantSpringCore: {
				DisplayName: Dormant Spring Core
				Tooltip:
					'''
					'The promise of bloom, suspended in slumber'
					Will awaken when the world grows stronger
					'''
			}
			DormantSummerCore: {
				DisplayName: Dormant Summer Core
				Tooltip:
					'''
					'Faded warmth waiting to ignite'
					Will awaken when the world grows stronger
					'''
			}
			DormantAutumnCore: {
				DisplayName: Dormant Autumn Core
				Tooltip:
					'''
					'The whisper of falling leaves, held in stasis'
					Will awaken when the world grows stronger
					'''
			}
			DormantWinterCore: {
				DisplayName: Dormant Winter Core
				Tooltip:
					'''
					'Frozen silence, preserved in crystal'
					Will awaken when the world grows stronger
					'''
			}
			VernalBar: {
				DisplayName: Vernal Bar
				Tooltip:
					'''
					'Forged from the essence of spring's rebirth'
					Polished metal infused with renewal
					'''
			}
			SolsticeBar: {
				DisplayName: Solstice Bar
				Tooltip:
					'''
					'The peak of summer's intensity made solid'
					Radiates with captured sunlight
					'''
			}
			HarvestBar: {
				DisplayName: Harvest Bar
				Tooltip:
					'''
					'The weight of autumn's final yield'
					Carries the dignity of endings
					'''
			}
			PermafrostBar: {
				DisplayName: Permafrost Bar
				Tooltip:
					'''
					'Winter's eternal stillness crystallized'
					Cold to the touch, yet full of potential
					'''
			}
			BlossomEssence: {
				DisplayName: Spring's Harmonic Essence
				Tooltip:
					'''
					'The first breath of spring captured'
					Guaranteed drop from Plantera (3-5)
					Essential for spring-themed crafting
					'''
			}
			SolarEssence: {
				DisplayName: Summer's Harmonic Essence
				Tooltip:
					'''
					'A fragment of the sun's zenith'
					Guaranteed drop from Golem (3-5)
					Essential for summer-themed crafting
					'''
			}
			DecayEssence: {
				DisplayName: Autumn's Harmonic Essence
				Tooltip:
					'''
					'The beauty of gentle decline'
					Guaranteed drop from Pumpking (3-5)
					Essential for autumn-themed crafting
					'''
			}
			FrostEssence: {
				DisplayName: Winter's Harmonic Essence
				Tooltip:
					'''
					'Perfect stillness given form'
					Guaranteed drop from Ice Queen (3-5)
					Essential for winter-themed crafting
					'''
			}
			SpringResonantEnergy: {
				DisplayName: Spring Resonant Energy
				Tooltip:
					'''
					'The harmonics of rebirth swirl within'
					Dropped by Primavera, Herald of Bloom
					'''
			}
			SummerResonantEnergy: {
				DisplayName: Summer Resonant Energy
				Tooltip:
					'''
					'Solar fury contained in pure energy'
					Dropped by L'Estate, Lord of the Zenith
					'''
			}
			AutumnResonantEnergy: {
				DisplayName: Autumn Resonant Energy
				Tooltip:
					'''
					'The melancholy of endings made manifest'
					Dropped by Autunno, the Withering Maestro
					'''
			}
			WinterResonantEnergy: {
				DisplayName: Winter Resonant Energy
				Tooltip:
					'''
					'Crystalline silence from the frozen finale'
					Dropped by L'Inverno, the Silent Finale
