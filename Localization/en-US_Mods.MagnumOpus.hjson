Mods: {
	MagnumOpus: {
		DropConditions.PostMoonLord: After Moon Lord has been defeated

		Items: {
			SwanLakeResonanceOre: {
				DisplayName: Swan Lake Resonance Ore
				Tooltip:
					'''
					'Crystallized grace from the celestial ballet'
					White resonant ore found in sky bubbles
					'''
			}

			LaCampanellaResonanceOre: {
				DisplayName: La Campanella Resonance Ore
				Tooltip:
					'''
					'The infernal bells ring beneath the scorching sands'
					Orange resonant ore, burning with virtuosic intensity
					Found where desert heat meets musical legend
					'''
			}

			EnigmaResonanceOre: {
				DisplayName: Enigma Resonance Ore
				Tooltip:
					'''
					'Mysterious variations crystallized in green'
					Green resonant ore found in jungle depths
					'''
			}

			FateResonanceOre: {
				DisplayName: Fate Resonance Ore
				Tooltip:
					'''
					'The threads of destiny made manifest'
					Pink resonant ore found in evil biomes
					Drops from Herald of Fate in Corruption/Crimson (post-Moon Lord)
					'''
			}

			EternalMoon: {
				DisplayName: Eternal Moon
				Tooltip:
					'''
					'The eternal cycle made blade  — each swing echoes moonlight on water'
					5-phase Tidal Lunar Cycle combo with escalating crescent waves
					Ghost reflection echoes on Half Moon, tidal detonation on Full Moon crescendo
					Critical hits spawn seeking lunar crystals
					Inflicts Musical Dissonance on enemies
					'''
			}

			MoonlightsCalling: {
				DisplayName: Moonlight's Calling
				Tooltip:
					'''
					Rapid-fire bouncing moonlight beams with prismatic refraction  — each bounce intensifies the spectral cascade
					Bounces 3+ split into spectral child beams  — light refracting through a crystal prism
					Final bounce detonates into a full prismatic spectral explosion with god rays and screen effects
					Right-click unleashes Serenade Mode  — a devastating prismatic mega-beam that pierces walls and enemies
					Serenade Mode: 40 mana, 3 second cooldown, 1.8x damage, infinite pierce
					Inflicts Musical Dissonance on enemies
					'The moon whispers secrets to those who listen  — each note a color, each color a truth'
					'''
			}

			StaffOfTheLunarPhases: {
				DisplayName: Staff of the Lunar Phases
				Tooltip:
					'''
					'The conductor raises the baton  — and the moonlight obeys'
					Parts the veil of moonlight, summoning a Goliath of Moonlight
					The Goliath fires devastating moonlight beams that ricochet between enemies
					Each beam hit restores 10 health
					Right-click to toggle Conductor Mode  — direct the Goliath's beams toward your cursor
					Inflicts Musical Dissonance on enemies
					'''
			}

			GrandPianoItem: {
				DisplayName: Grand Piano
				Tooltip:
					'''
					'The mystical instrument through which all symphonies resonate'
					Place and use with Score items to summon the musical bosses
					'''
			}

			ScoreOfEroica: {
				DisplayName: Score of Eroica
				Tooltip:
